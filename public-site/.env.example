NEXT_PUBLIC_FORCE_NO_SYNCED_DATA=false # Go down flow where you don't have extension installed yet
FORCE_UPGRADE_MODAL_TO_SHOW=false # Local-only escape hatch for unthrottled required upgrade-modal testing.

# Plain strings/booleans returned by /api/extension-client-messages.
UPGRADE_MSG="" # Non-empty text advertises the next patch version and shows the upgrade modal with this copy.
MODAL_MSG=""
AI_CHAT_FOCUS_MODAL_MSG=""
TUTORIAL_DISABLED_MSG=""
SHOW_UPGRADE_MODAL_BEFORE_MSG_MODAL=true
SHOW_MSG_MODAL_IF_UPGRADE_MODAL_IS_ACTIVE=false
