# Firebase
VITE_FIREBASE_HOSTING_URL=https://boilerplate-firebase-extension.firebaseapp.com # TODO: Replace with your Firebase hosting URL
VITE_PUBLIC_SITE_URL=http://localhost:4232 # Local dev target. Production builds are pinned in .env.production.

# Stripe
VITE_PREMIUM_STRIPE_PRICE_ID=price_1Se6QBTX0mvwmvJqI1 # TODO: Replace with Stripe price_id
VITE_PREMIUM_PRICE_TYPE=subscription # TODO: Replace with 'subscription' or 'payment' dependng on price_id
VITE_PREMIUM_ITEM_DESCRIPTION=product_description # TODO: Replace. Just used for transaction metadata — does nothing functional.

# OpenAI
# Configure OPENAI_API_KEY as a Firebase Functions secret instead of putting it in this file.
# Configure OPENAI_CHAT_MODEL in web/functions/.env so chat model selection stays server-owned.

# Testing flags
VITE_TEST_FLAG=false # Whether we're in test mode
VITE_TEST_FLAG_PREMIUM=true # Whether we have premium in test mode
SHOW_END_OF_TUTORIAL_ANIMATION=true # Play the mascot animation after completing the tutorial.

# Auth
HARD_REQUIREMENT_GOOGLE_SIGN_IN=true # When true, block the entire extension behind Google sign-in.
